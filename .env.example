# ==============================================================================
# VoiceMind AI Production Environment Variables Example Configuration
# ==============================================================================

# FastAPI Settings
ENVIRONMENT=production
SECRET_KEY=generate_a_secure_jwt_secret_signing_key_using_openssl_rand_hex_32

# PostgreSQL pgvector Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=choose_a_secure_database_password_here
POSTGRES_DB=voicemind

# Google Gemini API Configuration (Mandatory for AI features)
GOOGLE_API_KEY=AIzaSy...your_gemini_api_key_here

# Cloudflare R2 object storage (Mandatory for audio/exports/attachments)
R2_ACCOUNT_ID=your_cloudflare_account_id_here
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_BUCKET_NAME=voicemind-audio

# SMTP / Email Notification Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notifications@yourdomain.com
SMTP_PASSWORD=your_smtp_app_password_here
SMTP_FROM_EMAIL=noreply@yourdomain.com
